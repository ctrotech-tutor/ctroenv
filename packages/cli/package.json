{
  "name": "@ctroenv/cli",
  "version": "1.2.0",
  "description": "CLI tooling for CtroEnv — validate, generate, check, and document environment variables",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ctroenv": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "size": "size-limit",
    "typecheck": "tsc --noEmit"
  },
  "size-limit": [
    {
      "name": "index (programmatic)",
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true
    },
    {
      "name": "cli (binary)",
      "path": "dist/cli.js",
      "limit": "50 KB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@ctroenv/core": "^1.0.0",
    "@ctroenv/shared": "^1.0.0",
    "commander": "^13.1",
    "dotenv": "^16.4",
    "jiti": "^2.4",
    "picocolors": "^1.1",
    "chokidar": "^4.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctrotech-tutor/ctroenv.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ctroenv.vercel.app",
  "bugs": "https://github.com/ctrotech-tutor/ctroenv/issues",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "environment",
    "env",
    "cli",
    "validation",
    "typescript"
  ]
}
