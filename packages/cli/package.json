{
  "name": "@ctroenv/cli",
  "version": "1.0.0",
  "description": "CLI tooling for CtroEnv — validate, generate, check, and document environment variables",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ctroenv": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ctroenv/core": "^1.0.0",
    "@ctroenv/shared": "^1.0.0",
    "commander": "^13.1",
    "dotenv": "^16.4",
    "jiti": "^2.4",
    "picocolors": "^1.1",
    "chokidar": "^4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "environment",
    "env",
    "cli",
    "validation",
    "typescript"
  ]
}
