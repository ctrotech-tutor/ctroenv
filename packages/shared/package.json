{
  "name": "@ctroenv/shared",
  "version": "1.1.0",
  "description": "Shared utilities for CtroEnv — logger, type helpers, and cross-package tooling",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "size": "size-limit",
    "typecheck": "tsc --noEmit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB",
      "gzip": true
    }
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctrotech-tutor/ctroenv.git",
    "directory": "packages/shared"
  },
  "homepage": "https://ctroenv.vercel.app",
  "bugs": "https://github.com/ctrotech-tutor/ctroenv/issues",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "environment",
    "env",
    "utilities",
    "logger",
    "typescript"
  ]
}
