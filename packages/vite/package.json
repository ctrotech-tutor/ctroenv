{
  "name": "@ctroenv/vite",
  "version": "1.0.4",
  "description": "Vite adapter for CtroEnv — import.meta.env source and build-time validation plugin",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ctroenv/core": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "size": "size-limit",
    "typecheck": "tsc --noEmit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2 KB",
      "gzip": true
    }
  ],
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": false
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctrotech-tutor/ctroenv.git",
    "directory": "packages/vite"
  },
  "homepage": "https://ctroenv.vercel.app",
  "bugs": "https://github.com/ctrotech-tutor/ctroenv/issues",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "keywords": [
    "environment",
    "env",
    "vite",
    "plugin",
    "typescript"
  ]
}
