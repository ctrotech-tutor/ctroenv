{
  "name": "ctroenv",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared -w packages/core && npm run build -w packages/cli -w packages/nextjs -w packages/node -w packages/vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "size-all": "npm run size --workspaces",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "clean": "rimraf packages/core/dist packages/cli/dist packages/shared/dist packages/node/dist packages/vite/dist packages/nextjs/dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "semantic-release-monorepo": "^8.0.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "biome format"
    ],
    "*.{json,md,yaml}": [
      "biome format"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
